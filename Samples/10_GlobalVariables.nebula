namespace "GlobalVariables";
import "SharedScript";

native void WriteLine(string m);

int EntityCount = 0;

func void main() autoexec
{
    WriteLine("What is the max ent count?");
    WriteLine(string(SharedScript::MAX_ENT_COUNT));

    SharedScript::EntityCount += 1;

    WriteLine("Current entity count:" + string(SharedScript::EntityCount));
    WriteLine("Current LOCAL entity count:" + string(EntityCount));
}
